FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive \
    TZ=Asia/Seoul

# Install xrdp and dependencies so /etc/xrdp/* files exist before tests run.
# ufw and ssl-cert are included so their groups/configs are present.
# Lists are kept (no rm -rf) so setup_rdp.sh's apt-get calls succeed fast.
RUN apt-get update -q && \
    apt-get install -y --no-install-recommends \
        bash curl sudo python3 \
        xrdp dbus-x11 xauth \
        ufw ssl-cert

# Mock gnome-shell as "install ok installed" in the dpkg status database.
# This makes `dpkg -l gnome-shell | grep "^ii"` succeed without installing
# the full GNOME stack (which is too heavy for a test container).
RUN printf "\nPackage: gnome-shell\nStatus: install ok installed\nPriority: optional\nSection: universe/gnome\nInstalled-Size: 5000\nMaintainer: Ubuntu Developers <ubuntu-devel-discuss@lists.ubuntu.com>\nArchitecture: amd64\nVersion: 42.9-0ubuntu6\nDescription: graphical shell for the GNOME desktop\n" \
    >> /var/lib/dpkg/status

# Mock GDM config as it would appear on a real GNOME desktop install.
# Uses the commented form (#WaylandEnable=false) that disable_wayland() will fix.
RUN mkdir -p /etc/gdm3 && \
    printf "[daemon]\n#WaylandEnable=false\n\n[security]\n\n[xdmcp]\n\n[chooser]\n\n[debug]\n" \
    > /etc/gdm3/custom.conf

# Polkit dirs expected by configure_polkit()
RUN mkdir -p /etc/polkit-1/rules.d \
             /etc/polkit-1/localauthority/50-local.d

# Mock binaries shadow real ones via PATH prepend in test_inside.sh
COPY tests/mocks/ /usr/local/bin/mock_bins/
RUN chmod +x /usr/local/bin/mock_bins/*

COPY setup_rdp.sh         /opt/setup_rdp.sh
COPY tests/test_inside.sh /opt/test_inside.sh
RUN chmod +x /opt/setup_rdp.sh /opt/test_inside.sh

CMD ["/bin/bash", "/opt/test_inside.sh"]
